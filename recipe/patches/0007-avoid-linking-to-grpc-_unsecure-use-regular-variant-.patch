From a610ec1627b3b1b2a7b7602842c65926a16fa989 Mon Sep 17 00:00:00 2001
From: "H. Vetinari" <h.vetinari@gmx.com>
Date: Tue, 10 Feb 2026 11:43:39 +1100
Subject: [PATCH 7/8] avoid linking to grpc{,++}_unsecure; use regular variant
 instead

also link to absl_strings, whose linkage has been made private in grpc, see
https://github.com/conda-forge/grpc-cpp-feedstock/blob/main/recipe/patches/0005-mark-linkages-of-grpc-_unsecure-as-private.patch
---
 src/main/protobuf/BUILD |  2 +-
 third_party/grpc/BUILD  | 15 +++++----------
 2 files changed, 6 insertions(+), 11 deletions(-)

diff --git a/src/main/protobuf/BUILD b/src/main/protobuf/BUILD
index f8fce15..2909801 100755
--- a/src/main/protobuf/BUILD
+++ b/src/main/protobuf/BUILD
@@ -213,7 +213,7 @@ cc_grpc_library(
     grpc_only = True,
     deps = [
         ":command_server_cc_proto",
-        "@com_github_grpc_grpc//:grpc++_unsecure",
+        "@com_github_grpc_grpc//:grpc++",
     ],
 )
 
diff --git a/third_party/grpc/BUILD b/third_party/grpc/BUILD
index 1ef653c..822d03d 100755
--- a/third_party/grpc/BUILD
+++ b/third_party/grpc/BUILD
@@ -49,18 +49,13 @@ alias(
 
 alias(
     name = "grpc++_codegen_proto",
-    actual = select({
-        "//src/conditions:debian_build": "@debian_cc_deps//:grpc++_unsecure",
-        "//conditions:default": "@com_github_grpc_grpc//:grpc++_codegen_proto",
-    }),
+    actual = "grpc++",
 )
 
-alias(
-    name = "grpc++_unsecure",
-    actual = select({
-        "//src/conditions:debian_build": "@debian_cc_deps//:grpc++_unsecure",
-        "//conditions:default": "@com_github_grpc_grpc//:grpc++_unsecure",
-    }),
+cc_library(
+    name = "grpc++",
+    linkopts = ["-lgrpc++", "-lgrpc", "-lgpr", "-labsl_strings"],
+    visibility = ["//visibility:public"],
 )
 
 filegroup(
