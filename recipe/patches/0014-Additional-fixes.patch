diff --git a/MODULE.bazel b/MODULE.bazel
index 3b2bd3a..a7cb823 100755
--- a/MODULE.bazel
+++ b/MODULE.bazel
@@ -41,17 +41,25 @@ bazel_dep(name = "zstd-jni", version = "1.5.6-9")
 # Depend on apple_support first and then rules_cc so that the Xcode toolchain
 # from apple_support wins over the generic Unix toolchain from rules_cc.
 bazel_dep(name = "apple_support", version = "1.24.5")
-bazel_dep(name = "rules_cc", version = "0.2.14")
+bazel_dep(name = "rules_cc", version = "0.2.15")
 
 # The starlark rules in @rules_cc are hidden behind macros but docgen needs to
 # load the rule class directly, so we need to expose the cc_compatibility_proxy
 # repo for access to the symbols
 cc_compatibility_proxy = use_extension("@rules_cc//cc:extensions.bzl", "compatibility_proxy")
 use_repo(cc_compatibility_proxy, "cc_compatibility_proxy")
+local_path_override(
+    module_name = "abseil-cpp",
+    path = "./third_party/systemlibs/absl",
+)
 local_path_override(
     module_name = "protobuf",
     path = "./third_party/systemlibs/protobuf",
 )
+local_path_override(
+    module_name = "grpc",
+    path = "./third_party/systemlibs/grpc",
+)
 
 # TODO: wyv@ - add remoteapis to the BCR
 bazel_dep(name = "remoteapis", version = "")
@@ -70,13 +78,6 @@ single_version_override(
     version = "6.6",
 )
 
-single_version_override(
-    module_name = "grpc",
-    patch_strip = 1,
-    patches = ["//third_party:grpc-41584.patch"],
-    version = "GRPC_VERSION"
-)
-
 # TODO(pcloudy): Remove once the next version of rules_graalvm is available.
 single_version_override(
     module_name = "rules_graalvm",
@@ -88,6 +89,26 @@ single_version_override(
     ],
 )
 
+single_version_override(
+    module_name = "zstd-jni",
+    patch_strip = 1,
+    patches = ["//third_party:zstd-jni.patch"],
+)
+
+single_version_override(
+    module_name = "googleapis",
+    patch_strip = 1,
+    patches = ["//third_party:googleapis.patch"],
+    version = "0.0.0-20250604-de157ca3",
+)
+
+single_version_override(
+    module_name = "protoc-gen-validate",
+    patch_strip = 1,
+    patches = ["//third_party:protoc-gen-validate.patch"],
+    version = "1.2.1.bcr.1",
+)
+
 local_path_override(
     module_name = "remoteapis",
     path = "./third_party/remoteapis",
@@ -140,15 +161,15 @@ maven.install(
         "commons-collections:commons-collections:3.2.2",
         "commons-lang:commons-lang:2.6",
         "io.github.java-diff-utils:java-diff-utils:4.12",
-        "io.grpc:grpc-api:1.66.0",
-        "io.grpc:grpc-auth:1.66.0",
-        "io.grpc:grpc-context:1.66.0",
-        "io.grpc:grpc-core:1.66.0",
-        "io.grpc:grpc-inprocess:1.66.0",
-        "io.grpc:grpc-netty:1.66.0",
-        "io.grpc:grpc-protobuf:1.66.0",
-        "io.grpc:grpc-protobuf-lite:1.66.0",
-        "io.grpc:grpc-stub:1.66.0",
+        "io.grpc:grpc-api:GRPC_VERSION",
+        "io.grpc:grpc-auth:GRPC_VERSION",
+        "io.grpc:grpc-context:GRPC_VERSION",
+        "io.grpc:grpc-core:GRPC_VERSION",
+        "io.grpc:grpc-inprocess:GRPC_VERSION",
+        "io.grpc:grpc-netty:GRPC_VERSION",
+        "io.grpc:grpc-protobuf:GRPC_VERSION",
+        "io.grpc:grpc-protobuf-lite:GRPC_VERSION",
+        "io.grpc:grpc-stub:GRPC_VERSION",
         "io.netty:netty-buffer:4.1.119.Final",
