From 5c046b57f2e606c4dcf7cb4f6d7e9250b3955803 Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwe.korn@quantco.com>
Date: Thu, 12 Feb 2026 16:43:55 +0100
Subject: [PATCH 13/13] Load libunix_jni from prefix

---
 .../devtools/build/lib/jni/JniLoader.java     | 24 +++++++++++++++++--
 1 file changed, 22 insertions(+), 2 deletions(-)

diff --git a/src/main/java/com/google/devtools/build/lib/jni/JniLoader.java b/src/main/java/com/google/devtools/build/lib/jni/JniLoader.java
index 5ba0a8a..c4531fc 100755
--- a/src/main/java/com/google/devtools/build/lib/jni/JniLoader.java
+++ b/src/main/java/com/google/devtools/build/lib/jni/JniLoader.java
@@ -25,6 +25,7 @@ import java.io.InputStream;
 import java.io.OutputStream;
 import java.nio.file.Files;
 import java.nio.file.Path;
+import java.nio.file.Paths;
 import javax.annotation.Nullable;
 
 /** Generic code to interact with the platform-specific JNI code bundle. */
@@ -37,16 +38,35 @@ public final class JniLoader {
   static {
     Throwable jniLoadError;
     try {
+      String prefix = System.getenv("PREFIX");
+      if (prefix == null || prefix.isEmpty()) {
+          prefix = System.getenv("CONDA_PREFIX");
+      }
+
       switch (OS.getCurrent()) {
         case LINUX:
         case FREEBSD:
         case OPENBSD:
         case UNKNOWN:
-          loadLibrary("main/native/libunix_jni.so");
+          if (prefix != null && !prefix.isEmpty()) {
+            String libraryPath = Paths.get(prefix, "lib/bazel/libunix_jni.so")
+                                      .toAbsolutePath()
+                                      .toString();
+            System.load(libraryPath);
+          } else {
+            loadLibrary("main/native/libunix_jni.so");
+          }
           break;
 
         case DARWIN:
-          loadLibrary("main/native/libunix_jni.dylib");
+          if (prefix != null && !prefix.isEmpty()) {
+            String libraryPath = Paths.get(prefix, "lib/bazel/libunix_jni.dylib")
+                                      .toAbsolutePath()
+                                      .toString();
+            System.load(libraryPath);
+          } else {
+            loadLibrary("main/native/libunix_jni.dylib");
+          }
           break;
 
         case WINDOWS:
