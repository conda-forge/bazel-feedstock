From 4e6212b9d73553da4c015d61614a47f0ad92351c Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwe.korn@quantco.com>
Date: Fri, 13 Feb 2026 06:47:54 +0100
Subject: [PATCH 13/14] fix

---
 compile.sh | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/compile.sh b/compile.sh
index e95990a..abadf80 100755
--- a/compile.sh
+++ b/compile.sh
@@ -63,7 +63,7 @@ fi
 # The bootstrapped Bazel has no embedded version, so native.bazel_version returns "".
 # bazel_features treats "" as a dev version (999999.999999.999999), causing rules_cc's
 # compatibility proxy to incorrectly select the Bazel 9+ code path.
-export BAZEL_DEV_VERSION_OVERRIDE="8.5.1"
+export BAZEL_DEV_VERSION_OVERRIDE="${PKG_VERSION}"
 
 source scripts/bootstrap/bootstrap.sh
 
