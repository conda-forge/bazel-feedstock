From 5858a00695619bd09f9bc4ee088e63b4f637cc6d Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwe.korn@quantco.com>
Date: Sat, 12 Feb 2022 22:04:35 +0100
Subject: [PATCH 3/8] Use conda packages for build tools

---
 src/tools/singlejar/BUILD | 45 +++++++++------------------------------
 third_party/ijar/BUILD    | 17 +++++++--------
 tools/zip/BUILD.tools     | 13 +++++++----
 3 files changed, 27 insertions(+), 48 deletions(-)

diff --git a/src/tools/singlejar/BUILD b/src/tools/singlejar/BUILD
index 93f4e6c4ea..e9303971a5 100644
--- a/src/tools/singlejar/BUILD
+++ b/src/tools/singlejar/BUILD
@@ -80,45 +80,20 @@ release_archive(
     visibility = ["//src:__pkg__"],
 )
 
-cc_binary(
+genrule(
     name = "singlejar",
-    srcs = [
-        "singlejar_main.cc",
-    ],
-    linkopts = select({
-        "//src/conditions:freebsd": ["-lm"],
-        "//src/conditions:openbsd": ["-lm"],
-        "//conditions:default": [],
-    }),
-    linkstatic = 1,
-    visibility = ["//visibility:public"],
-    deps = [
-        ":combiners",
-        ":options",
-        ":output_jar",
-        "@zlib",
-    ],
+    outs = ["singlejar.bin"],
+    cmd = "ln -s ${BUILD_PREFIX}/bin/singlejar $@",
+    executable = 1,
+    visibility = ["//visibility:public"]
 )
 
-cc_binary(
+genrule(
     name = "singlejar_local",
-    srcs = [
-        "singlejar_local_main.cc",
-    ],
-    linkopts = select({
-        "//src/conditions:freebsd": ["-lm"],
-        "//src/conditions:openbsd": ["-lm"],
-        "//conditions:default": [],
-    }),
-    linkstatic = 1,
-    visibility = ["//visibility:public"],
-    deps = [
-        ":combiners",
-        ":desugar_checking",
-        ":options",
-        ":output_jar",
-        "@zlib",
-    ],
+    outs = ["singlejar_local.bin"],
+    cmd = "ln -s ${BUILD_PREFIX}/bin/singlejar_local $@",
+    executable = 1,
+    visibility = ["//visibility:public"]
 )
 
 cc_test(
diff --git a/third_party/ijar/BUILD b/third_party/ijar/BUILD
index b317ae2a04..e950db6df9 100644
--- a/third_party/ijar/BUILD
+++ b/third_party/ijar/BUILD
@@ -72,21 +72,20 @@ cc_library(
     ],
 )
 
-cc_binary(
+genrule(
     name = "zipper",
-    srcs = ["zip_main.cc"],
+    outs = ["zipper.bin"],
+    cmd = "ln -s ${BUILD_PREFIX}/bin/zipper $@",
+    executable = 1,
     visibility = ["//visibility:public"],
-    deps = [":zip"],
 )
 
-cc_binary(
+genrule(
     name = "ijar",
-    srcs = [
-        "classfile.cc",
-        "ijar.cc",
-    ],
+    outs = ["ijar.bin"],
+    cmd = "ln -s ${BUILD_PREFIX}/bin/ijar $@",
+    executable = 1,
     visibility = ["//visibility:public"],
-    deps = [":zip"],
 )
 
 filegroup(
diff --git a/tools/zip/BUILD.tools b/tools/zip/BUILD.tools
index 478e7a1722..ed35a5a4fd 100644
--- a/tools/zip/BUILD.tools
+++ b/tools/zip/BUILD.tools
@@ -2,12 +2,17 @@ load("@platforms//host:constraints.bzl", "HOST_CONSTRAINTS")
 
 package(default_visibility = ["//visibility:public"])
 
+genrule(
+    name = "zipper-exec",
+    outs = ["zipper.bin"],
+    cmd_bash = "ln -s `which zipper` $@",
+    executable = 1,
+    visibility = ["//visibility:public"],
+)
+
 filegroup(
     name = "zipper",
-    srcs = select({
-        ":matches_host_constraints": glob(["zipper/*"]),
-        "//conditions:default": ["//third_party/ijar:zipper"],
-    }),
+    srcs = [":zipper-exec"],
 )
 
 alias(
