diff --git a/compile.sh b/compile.sh
index 0c0edf6..abadf80 100755
--- a/compile.sh
+++ b/compile.sh
@@ -60,8 +60,17 @@ if [[ $PLATFORM == "darwin" ]] && \
   EXTRA_BAZEL_ARGS="${EXTRA_BAZEL_ARGS-} --define IPHONE_SDK=1"
 fi
 
+# The bootstrapped Bazel has no embedded version, so native.bazel_version returns "".
+# bazel_features treats "" as a dev version (999999.999999.999999), causing rules_cc's
+# compatibility proxy to incorrectly select the Bazel 9+ code path.
+export BAZEL_DEV_VERSION_OVERRIDE="${PKG_VERSION}"
+
 source scripts/bootstrap/bootstrap.sh
 
+# Make Java code compatible with newer protobuf release now as the bootstrap builds with the old release
+sed -i 's/includingDefaultValueFields/alwaysPrintFieldsWithNoPresence/g' src/main/java/com/google/devtools/build/lib/util/io/MessageOutputStreamWrapper.java
+sed -i 's/includingDefaultValueFields/alwaysPrintFieldsWithNoPresence/g' src/main/java/com/google/devtools/build/lib/worker/JsonWorkerMessageProcessor.java
+
 new_step 'Building Bazel with Bazel'
 display "."
 log "Building output/bazel"
diff --git a/src/main/cpp/BUILD b/src/main/cpp/BUILD
index c973f0a..944f1e6 100755
--- a/src/main/cpp/BUILD
+++ b/src/main/cpp/BUILD
@@ -93,6 +93,15 @@ cc_library(
     ],
 )
 
+# cannot do `[...] + select(...)` in starlark, so factor out common libraries into
+# a variable; note that this is likely not the full list, because we're inheriting
+# the linkopts from protobuf (see third_party/systemlibs/protobuf/BUILD), so several
+# abseil libraries will already be present
+_CLIENT_LINKOPTS = [
+    "-labsl_log_severity",
+    "-labsl_synchronization",
+]
+
 cc_binary(
     name = "client",
     srcs = [
@@ -110,7 +119,7 @@ cc_binary(
         "//conditions:default": ["-Wno-sign-compare"],
     }),
     linkopts = select({
-        "//src/conditions:darwin": [
+        "//src/conditions:darwin": _CLIENT_LINKOPTS + [
         ],
         "//src/conditions:freebsd": [
             "-lprocstat",
@@ -120,7 +129,7 @@ cc_binary(
         ],
         "//src/conditions:windows": [
         ],
-        "//conditions:default": [
+        "//conditions:default": _CLIENT_LINKOPTS + [
             "-lrt",
             "-ldl",
         ],
@@ -143,6 +152,21 @@ cc_binary(
         "//src/main/protobuf:command_server_cc_grpc",
         "//src/main/protobuf:command_server_cc_proto",
         "//third_party/ijar:zip",
+        # required dependencies we need to add because we're unvendoring; however, any
+        # `@abseil-cpp//absl/foo` added here don't actually take effect from the POV
+        # of the linker, because abseil will by default look for a static library, e.g.
+        #   bazel-out/darwin-opt/bin/external/abseil-cpp~/absl/foo/libfoo.a
+        # This could be because we're building abseil itself with CMake rather than
+        # bazel (so the metadata might be off). Rather than come up with complicated
+        # wrappers, we abuse linkopts to add the right libraries (see above).
+        "@abseil-cpp//absl/base:log_severity",
+        "@abseil-cpp//absl/log:absl_check",
+        "@abseil-cpp//absl/container:flat_hash_map",
+        "@abseil-cpp//absl/container:btree",
+        "@abseil-cpp//absl/log:log",
+        "@abseil-cpp//absl/log:absl_log",
+        "@abseil-cpp//absl/strings:cord",
+        "@abseil-cpp//absl/status:statusor",
     ],
 )
 
