From af6cfcadfe94541eb46f762f4506f9b09355800f Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwelk@xhochy.com>
Date: Sun, 21 Mar 2021 21:26:54 +0100
Subject: [PATCH 8/8] Build with native dependencies

---
 MODULE.bazel                                  | 71 +++++++------------
 compile.sh                                    |  9 +++
 src/main/cpp/BUILD                            | 13 +++-
 .../java/com/google/devtools/build/lib/BUILD  |  2 +-
 third_party/grpc/BUILD                        | 11 +--
 5 files changed, 53 insertions(+), 53 deletions(-)

diff --git a/MODULE.bazel b/MODULE.bazel
index 9b5945d..0eb6e9a 100755
--- a/MODULE.bazel
+++ b/MODULE.bazel
@@ -27,6 +27,21 @@
 bazel_dep(name = "re2", version = "2025-11-05.bcr.1")
 bazel_dep(name = "rules_graalvm", version = "0.11.1")
 bazel_dep(name = "rules_java", version = "9.1.0")
+local_path_override(
+    module_name = "abseil-cpp",
+    path = "./third_party/systemlibs/abseil-cpp",
+)
+
+local_path_override(
+    module_name = "protobuf",
+    path = "./third_party/systemlibs/protobuf",
+)
+
+local_path_override(
+    module_name = "grpc",
+    path = "./third_party/systemlibs/grpc",
+)
+
 bazel_dep(name = "bazel_features", version = "1.42.1")
 bazel_dep(name = "rules_jvm_external", version = "6.6")
 bazel_dep(name = "rules_license", version = "1.0.0")
@@ -101,22 +116,6 @@
     version = "1.2.1.bcr.1",
 )
 
-# 1. Expose @com_google_protobuf//java/core:lite_runtime_only
-# due to https://github.com/protocolbuffers/protobuf/commit/079be27925955348d1b3cb30ffbfa33dcec5778c
-# We need to package the lite runtime jar for Bazel's bootstrap build
-# 2. Partially revert of https://github.com/protocolbuffers/protobuf/commit/7ec5e19c0743b80c5097434a05cc0e972e7b4e7a
-# to support grpc
-# 3. Pull in the removal of the memoizedIsInitialized field for messages with no
-# required fields early. This reduces the memory usage of Bazel and avoids
-# spread in memory usage between Bazel and Blaze.
-# https://github.com/protocolbuffers/protobuf/blob/adf9e8b80fd10398b82e16c4ea72f2d2cffb0e9b/src/google/protobuf/compiler/java/full/message.cc#L884C1-L899C6
-single_version_override(
-    module_name = "protobuf",
-    patch_strip = 1,
-    patches = ["//third_party:protobuf.patch"],
-    version = "33.4",
-)
-
 # Remove once the following PRs are available in a grpc-java release.
 #   https://github.com/grpc/grpc-java/pull/12148
 #   https://github.com/grpc/grpc-java/pull/12207
diff --git a/compile.sh b/compile.sh
index 0c0edf6..abadf80 100755
--- a/compile.sh
+++ b/compile.sh
@@ -60,8 +60,17 @@ if [[ $PLATFORM == "darwin" ]] && \
   EXTRA_BAZEL_ARGS="${EXTRA_BAZEL_ARGS-} --define IPHONE_SDK=1"
 fi
 
+# The bootstrapped Bazel has no embedded version, so native.bazel_version returns "".
+# bazel_features treats "" as a dev version (999999.999999.999999), causing rules_cc's
+# compatibility proxy to incorrectly select the Bazel 9+ code path.
+export BAZEL_DEV_VERSION_OVERRIDE="${PKG_VERSION}"
+
 source scripts/bootstrap/bootstrap.sh
 
+# Make Java code compatible with newer protobuf release now as the bootstrap builds with the old release
+sed -i 's/includingDefaultValueFields/alwaysPrintFieldsWithNoPresence/g' src/main/java/com/google/devtools/build/lib/util/io/MessageOutputStreamWrapper.java
+sed -i 's/includingDefaultValueFields/alwaysPrintFieldsWithNoPresence/g' src/main/java/com/google/devtools/build/lib/worker/JsonWorkerMessageProcessor.java
+
 new_step 'Building Bazel with Bazel'
 display "."
 log "Building output/bazel"
diff --git a/src/main/cpp/BUILD b/src/main/cpp/BUILD
index c973f0a..5cc542c 100755
--- a/src/main/cpp/BUILD
+++ b/src/main/cpp/BUILD
@@ -93,6 +93,15 @@ cc_library(
     ],
 )
 
+# cannot do `[...] + select(...)` in starlark, so factor out common libraries into
+# a variable; note that this is likely not the full list, because we're inheriting
+# the linkopts from protobuf (see third_party/systemlibs/protobuf/BUILD), so several
+# abseil libraries will already be present
+_CLIENT_LINKOPTS = [
+    "-labsl_log_severity",
+    "-labsl_synchronization",
+]
+
 cc_binary(
     name = "client",
     srcs = [
@@ -110,7 +119,7 @@ cc_binary(
         "//conditions:default": ["-Wno-sign-compare"],
     }),
     linkopts = select({
-        "//src/conditions:darwin": [
+        "//src/conditions:darwin": _CLIENT_LINKOPTS + [
         ],
         "//src/conditions:freebsd": [
             "-lprocstat",
@@ -120,7 +129,7 @@ cc_binary(
         ],
         "//src/conditions:windows": [
         ],
-        "//conditions:default": [
+        "//conditions:default": _CLIENT_LINKOPTS + [
             "-lrt",
             "-ldl",
         ],
diff --git a/src/main/java/com/google/devtools/build/lib/BUILD b/src/main/java/com/google/devtools/build/lib/BUILD
index d385177..db65056 100755
--- a/src/main/java/com/google/devtools/build/lib/BUILD
+++ b/src/main/java/com/google/devtools/build/lib/BUILD
@@ -582,7 +582,7 @@ java_library(
         "//third_party:guava",
         "//third_party:jsr305",
         "@com_google_protobuf//:protobuf_java",
-        "@com_google_protobuf//java/util",
+        "@com_google_protobuf//:protobuf_java_util",
         "@zstd-jni//:zstd-jni",
     ],
 )
diff --git a/third_party/grpc/BUILD b/third_party/grpc/BUILD
index 822d03d..f307b1d 100755
--- a/third_party/grpc/BUILD
+++ b/third_party/grpc/BUILD
@@ -13,6 +13,7 @@
 # WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
 # See the License for the specific language governing permissions and
 # limitations under the License.
+load("@rules_cc//cc:cc_library.bzl", "cc_library")
 load("@rules_license//rules:license.bzl", "license")
 
 licenses(["notice"])  # Apache v2
@@ -39,12 +40,12 @@ filegroup(
     ],
 )
 
-alias(
+genrule(
     name = "cpp_plugin",
-    actual = select({
-        "//src/conditions:debian_build": "@debian_bin_deps//:grpc-cpp-plugin",
-        "//conditions:default": "@com_github_grpc_grpc//src/compiler:grpc_cpp_plugin",
-    }),
+    outs = ["grpc-cpp-plugin.out"],
+    cmd = "ln -s ${BUILD_PREFIX}/bin/grpc_cpp_plugin $@",
+    executable = 1,
+    visibility = ["//visibility:public"],
 )
 
 alias(
