From 7e7168e4b56e0cc722a010265e3adecb50e7d68d Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwe.korn@quantco.com>
Date: Fri, 8 Nov 2024 22:04:59 +0100
Subject: [PATCH 11/15] Add missing absl dependency

---
 src/main/cpp/BUILD                            | 28 +++++++-
 .../systemlibs/protobuf/toolchain/BUILD       |  0
 .../protobuf/toolchain/platforms.bzl          | 64 +++++++++++++++++++
 3 files changed, 90 insertions(+), 2 deletions(-)
 create mode 100644 third_party/systemlibs/protobuf/toolchain/BUILD
 create mode 100644 third_party/systemlibs/protobuf/toolchain/platforms.bzl

diff --git a/src/main/cpp/BUILD b/src/main/cpp/BUILD
index c973f0a..944f1e6 100755
--- a/src/main/cpp/BUILD
+++ b/src/main/cpp/BUILD
@@ -93,6 +93,15 @@ cc_library(
     ],
 )
 
+# cannot do `[...] + select(...)` in starlark, so factor out common libraries into
+# a variable; note that this is likely not the full list, because we're inheriting
+# the linkopts from protobuf (see third_party/systemlibs/protobuf/BUILD), so several
+# abseil libraries will already be present
+_CLIENT_LINKOPTS = [
+    "-labsl_log_severity",
+    "-labsl_synchronization",
+]
+
 cc_binary(
     name = "client",
     srcs = [
@@ -110,7 +119,7 @@ cc_binary(
         "//conditions:default": ["-Wno-sign-compare"],
     }),
     linkopts = select({
-        "//src/conditions:darwin": [
+        "//src/conditions:darwin": _CLIENT_LINKOPTS + [
         ],
         "//src/conditions:freebsd": [
             "-lprocstat",
@@ -120,7 +129,7 @@ cc_binary(
         ],
         "//src/conditions:windows": [
         ],
-        "//conditions:default": [
+        "//conditions:default": _CLIENT_LINKOPTS + [
             "-lrt",
             "-ldl",
         ],
@@ -143,6 +152,21 @@ cc_binary(
         "//src/main/protobuf:command_server_cc_grpc",
         "//src/main/protobuf:command_server_cc_proto",
         "//third_party/ijar:zip",
+        # required dependencies we need to add because we're unvendoring; however, any
+        # `@abseil-cpp//absl/foo` added here don't actually take effect from the POV
+        # of the linker, because abseil will by default look for a static library, e.g.
+        #   bazel-out/darwin-opt/bin/external/abseil-cpp~/absl/foo/libfoo.a
+        # This could be because we're building abseil itself with CMake rather than
+        # bazel (so the metadata might be off). Rather than come up with complicated
+        # wrappers, we abuse linkopts to add the right libraries (see above).
+        "@abseil-cpp//absl/base:log_severity",
+        "@abseil-cpp//absl/log:absl_check",
+        "@abseil-cpp//absl/container:flat_hash_map",
+        "@abseil-cpp//absl/container:btree",
+        "@abseil-cpp//absl/log:log",
+        "@abseil-cpp//absl/log:absl_log",
+        "@abseil-cpp//absl/strings:cord",
+        "@abseil-cpp//absl/status:statusor",
     ],
 )
 
diff --git a/third_party/systemlibs/protobuf/toolchain/BUILD b/third_party/systemlibs/protobuf/toolchain/BUILD
new file mode 100644
index 0000000..e69de29
diff --git a/third_party/systemlibs/protobuf/toolchain/platforms.bzl b/third_party/systemlibs/protobuf/toolchain/platforms.bzl
new file mode 100644
index 0000000..dbd386a
--- /dev/null
+++ b/third_party/systemlibs/protobuf/toolchain/platforms.bzl
@@ -0,0 +1,64 @@
+"List of published platforms on protobuf GitHub releases"
+
+# Keys are chosen to match the filenames published on protocolbuffers/protobuf releases
+# NB: keys in this list are nearly identical to /toolchain/BUILD.bazel#TOOLCHAINS
+# Perhaps we should share code.
+PROTOBUF_PLATFORMS = {
+    # "k8", # this is in /toolchain/BUILD.bazel but not a released platform
+    # "osx-universal_binary", # this is not in /toolchain/BUILD.bazel
+    # but also Bazel will never request it, as we have a darwin binary for each architecture
+    "linux-aarch_64": {
+        "compatible_with": [
+            "@platforms//os:linux",
+            "@platforms//cpu:aarch64",
+        ],
+    },
+    "linux-ppcle_64": {
+        "compatible_with": [
+            "@platforms//os:linux",
+            "@platforms//cpu:ppc64le",
+        ],
+    },
+    "linux-s390_64": {
+        "compatible_with": [
+            "@platforms//os:linux",
+            "@platforms//cpu:s390x",
+        ],
+    },
+    "linux-x86_32": {
+        "compatible_with": [
+            "@platforms//os:linux",
+            "@platforms//cpu:x86_32",
+        ],
+    },
+    "linux-x86_64": {
+        "compatible_with": [
+            "@platforms//os:linux",
+            "@platforms//cpu:x86_64",
+        ],
+    },
+    "osx-aarch_64": {
+        "compatible_with": [
+            "@platforms//os:macos",
+            "@platforms//cpu:aarch64",
+        ],
+    },
+    "osx-x86_64": {
+        "compatible_with": [
+            "@platforms//os:macos",
+            "@platforms//cpu:x86_64",
+        ],
+    },
+    "win32": {
+        "compatible_with": [
+            "@platforms//os:windows",
+            "@platforms//cpu:x86_32",
+        ],
+    },
+    "win64": {
+        "compatible_with": [
+            "@platforms//os:windows",
+            "@platforms//cpu:x86_64",
+        ],
+    },
+}
