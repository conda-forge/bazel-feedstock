+package(
+    default_applicable_licenses = [":license"],
+    default_visibility = ["//visibility:public"],
+)
+
+filegroup(
+    name = "srcs",
+    srcs = glob(["**"]) + [
+        "//third_party/grpc/bazel:srcs",
+    ],
+)
+
+genrule(
+    name = "cpp_plugin",
+    outs = ["grpc-cpp-plugin.out"],
+    cmd = "ln -s /Users/uwe/.pixi/envs/conda-build/conda-bld/bazel_1770922284082/_build_env/bin/grpc_cpp_plugin $@",
+    executable = 1,
+    visibility = ["//visibility:public"],
+)
+
+alias(
+    name = "grpc++_codegen_proto",
+    actual = "grpc++",
+)
+
+cc_library(
+    name = "grpc++",
+    linkopts = ["-lgrpc++", "-lgrpc", "-lgpr", "-labsl_strings"],
+    visibility = ["//visibility:public"],
+)
+
+filegroup(
+    name = "embedded_tools_srcs",
+    srcs = [
+        "BUILD.tools",
+        "build_defs.bzl",
+    ],
+)
